# Keep the build context small & the image lean.
.git/
.gitignore
.venv/
.varuna/
**/__pycache__/
**/*.py[cod]
.env
.env.example

# Data & pipeline artifacts (backend reads BigQuery, not local files)
data/
ingestion/
ml/
deploy/

# Frontend: the Node build stage needs source (package*.json, src/, index.html,
# configs). Only these are excluded:
frontend/node_modules/
frontend/dist/

# Docs / misc
*.md
!README.md
scratchpad/
