# Copy to .env and fill in. .env is gitignored.
GEMINI_API_KEY=your-google-ai-studio-key
# Comma-separated fallback chain (each model has its own free-tier quota bucket).
GEMINI_MODELS=gemini-2.5-flash,gemini-flash-latest,gemini-2.0-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-flash-lite-latest
GOOGLE_CLOUD_PROJECT=your-gcp-project
BQ_DATASET=varuna
BQ_LOCATION=asia-south1
